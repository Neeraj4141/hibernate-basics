<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.rays.aucation.AucationItem" table="AUCATIONITEM">

        <id name="id" type="int">
            <column name="ID"/>
            <generator class="assigned"/>
        </id>

        <property name="description" type="java.lang.String">
            <column name="DESCRIPTION"/>
        </property>

        <!-- Correct One-To-Many Mapping -->
        <set name="bids" table="BIDS" cascade="all" lazy="true">
            <key column="auction_id"/>
            <one-to-many class="com.rays.aucation.Bids"/>
        </set>

    </class>
</hibernate-mapping>